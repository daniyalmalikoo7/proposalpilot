// ProposalPilot — Prisma Schema
// Before first migration, enable pgvector in your database:
//   psql -d your_db -c "CREATE EXTENSION IF NOT EXISTS vector;"
//
// Run migrations:
//   npx prisma migrate dev --name init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ─── Tenant / Auth ────────────────────────────────────────────────────────────

model Organization {
  id                   String   @id @default(cuid())
  clerkOrgId           String   @unique
  name                 String
  plan                 String   @default("starter") // starter | growth | scale | enterprise
  monthlyProposalLimit Int      @default(10)
  stripeCustomerId     String?  @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users              User[]
  proposals          Proposal[]
  knowledgeBaseItems KnowledgeBaseItem[]
  brandVoice         BrandVoice?

  @@index([clerkOrgId])
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  orgId     String
  createdAt DateTime @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  proposals Proposal[]

  @@index([orgId])
}

// ─── Proposals ────────────────────────────────────────────────────────────────

model Proposal {
  id         String    @id @default(cuid())
  orgId      String
  userId     String
  title      String
  clientName String?
  // Uppercase values mirror the ProposalStatusSchema Zod enum in routers
  status     String    @default("DRAFT")
  deadline   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  org              Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user             User                   @relation(fields: [userId], references: [id])
  rfpSource        RFPSource?
  requirements     ExtractedRequirement[]
  sections         ProposalSection[]
  complianceMatrix ComplianceMatrix?
  winLoss          WinLossRecord?

  @@index([orgId, status])
  @@index([userId])
}

model RFPSource {
  id            String   @id @default(cuid())
  proposalId    String   @unique
  fileName      String
  fileSizeBytes Int
  mimeType      String
  storageKey    String   // Cloudflare R2 object key
  extractedText String   @db.Text
  pageCount     Int?
  chunkCount    Int      @default(0)
  createdAt     DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
}

model ExtractedRequirement {
  id          String  @id @default(cuid())
  proposalId  String
  section     String
  requirement String  @db.Text
  priority    String  @default("medium") // high | medium | low
  addressed   Boolean @default(false)

  proposal Proposal          @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  sections ProposalSection[] @relation("RequirementAddressedBy")

  @@index([proposalId])
}

model ProposalSection {
  id              String   @id @default(cuid())
  proposalId      String
  order           Int
  title           String
  content         String   @db.Text
  confidenceScore Float    @default(0)
  citations       Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  proposal     Proposal               @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  requirements ExtractedRequirement[] @relation("RequirementAddressedBy")
  kbItems      KnowledgeBaseItem[]    @relation("SectionCitations")

  @@index([proposalId, order])
}

model ComplianceMatrix {
  id          String   @id @default(cuid())
  proposalId  String   @unique
  matrix      Json
  score       Float    @default(0)
  generatedAt DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
}

model WinLossRecord {
  id         String   @id @default(cuid())
  proposalId String   @unique
  outcome    String   // WON | LOST
  feedback   String?  @db.Text
  dealValue  Float?
  competitor String?
  decidedAt  DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
}

// ─── Knowledge Base ───────────────────────────────────────────────────────────

model KnowledgeBaseItem {
  id       String   @id @default(cuid())
  orgId    String
  // Values: CASE_STUDY | PAST_PROPOSAL | METHODOLOGY | TEAM_BIO | PRICING | CERTIFICATE | OTHER
  type     String
  title    String
  content  String   @db.Text
  fileUrl  String?  // Optional R2 URL for the original document
  isActive Boolean  @default(true)
  isWin    Boolean  @default(false)
  metadata Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sections ProposalSection[] @relation("SectionCitations")
  chunks   KbChunk[]

  @@index([orgId, type])
  @@index([orgId, isActive])
}

// Per-chunk embeddings for precise vector retrieval.
// Each KnowledgeBaseItem is split into overlapping chunks (≈500 tokens, 50 overlap).
// searchSimilar queries this table, then aggregates to the parent document level.
model KbChunk {
  id         String   @id @default(cuid())
  itemId     String
  index      Int      // ordinal position within the parent document
  text       String   @db.Text
  tokenCount Int
  // pgvector — 1024 dims (Voyage AI voyage-3). IVFFlat index: prisma/manual-migrations/001_ivfflat_kbchunk_embedding.sql
  embedding  Unsupported("vector(1024)")?
  createdAt  DateTime @default(now())

  item KnowledgeBaseItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model ProcessedWebhookEvent {
  id             String   @id @default(cuid())
  stripeEventId  String   @unique
  processedAt    DateTime @default(now())

  @@index([stripeEventId])
}

model BrandVoice {
  id          String   @id @default(cuid())
  orgId       String   @unique
  tone        String
  style       Json     @default("{}")   // { formality, length, perspective }
  terminology Json     @default("[]")   // preferred terms
  analyzedAt  DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}
