# ============================================
# Application
# ============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=  # Generate with: openssl rand -base64 32

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/myapp?schema=public

# ============================================
# Authentication (Clerk)
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ============================================
# AI / LLM Providers
# ============================================
ANTHROPIC_API_KEY=  # Primary AI provider
VOYAGE_API_KEY=     # Embedding provider (optional — KB search falls back to full-text)
# OPENAI_API_KEY=   # Fallback provider (optional)

# AI Configuration
AI_PRIMARY_MODEL=claude-sonnet-4-20250514
AI_FALLBACK_MODEL=claude-haiku-4-5-20251001
AI_MAX_TOKENS_PER_REQUEST=4096
AI_MAX_COST_PER_USER_DAY=1.00  # USD
AI_CACHE_TTL_SECONDS=3600
AI_RATE_LIMIT_PER_MINUTE=20

# ============================================
# Monitoring & Observability
# ============================================
SENTRY_DSN=              # Error tracking — get from sentry.io
NEXT_PUBLIC_POSTHOG_KEY= # Analytics — get from posthog.com
VERCEL_ANALYTICS_ID=     # Vercel analytics (optional)
LOG_LEVEL=info           # debug | info | warn | error

# AI Cost Alerting
AI_COST_ALERT_DAILY_USD=50.00  # Alert when daily AI spend exceeds this
AI_EVAL_REGRESSION_THRESHOLD=0.05  # Alert when eval score drops by this amount

# ============================================
# External Services
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# RESEND_API_KEY=
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ============================================
# Claude Code (development tooling)
# ============================================
GITHUB_TOKEN=  # For MCP GitHub server
# CLAUDE_CODE_ENABLE_AGENT_TEAMS=1
