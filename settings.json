{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read", "Edit", "MultiEdit", "Write",
      "Bash(npm run *)", "Bash(npx *)", "Bash(node *)",
      "Bash(pip install *)", "Bash(semgrep *)", "Bash(gitleaks *)",
      "Bash(git status)", "Bash(git diff *)", "Bash(git add *)", "Bash(git commit:*)",
      "Bash(git log *)", "Bash(git tag *)",
      "Bash(curl *)", "Bash(lsof *)", "Bash(kill *)",
      "Bash(find *)", "Bash(grep *)", "Bash(wc *)", "Bash(head *)", "Bash(tail *)",
      "Bash(cat *)", "Bash(ls *)", "Bash(mkdir *)", "Bash(cp *)",
      "Grep", "Glob", "LS"
    ],
    "deny": [
      "Bash(rm -rf *)", "Bash(git push *)", "Bash(sudo:*)",
      "Bash(npm audit fix --force*)", "Edit(.env)"
    ]
  }
}
