# ============================================
# Application
# ============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=  # Generate with: openssl rand -base64 32

# ============================================
# Database (from Supabase)
# ============================================
# Connect to Supabase via connection pooling
DATABASE_URL=

# Direct connection to the database. Used for migrations
DIRECT_URL=

# ============================================
# Authentication (Clerk)
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Redirect URLs are set via ClerkProvider props (signInFallbackRedirectUrl / signUpFallbackRedirectUrl)

# ============================================
# Stripe (from Stripe dashboard)
# ============================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ============================================
# AI / LLM Providers
# ============================================
# Primary AI provider (Google Gemini — free tier available)
GOOGLE_GEMINI_API_KEY=

# Embeddings (from Voyage AI)
VOYAGE_API_KEY=     # Optional — KB search falls back to full-text if not set

# AI Configuration
AI_MAX_TOKENS_PER_REQUEST=4096
AI_MAX_COST_PER_USER_DAY=1.00  # USD
AI_CACHE_TTL_SECONDS=3600
AI_RATE_LIMIT_PER_MINUTE=20

# ============================================
# Monitoring & Observability
# ============================================
SENTRY_DSN=              # Error tracking — get from sentry.io
NEXT_PUBLIC_POSTHOG_KEY= # Analytics — get from posthog.com
VERCEL_ANALYTICS_ID=     # Vercel analytics (optional)
LOG_LEVEL=info           # debug | info | warn | error

# AI Cost Alerting
AI_COST_ALERT_DAILY_USD=50.00
AI_EVAL_REGRESSION_THRESHOLD=0.05

# ============================================
# Claude Code (development tooling)
# ============================================
GITHUB_TOKEN=  # For MCP GitHub server
