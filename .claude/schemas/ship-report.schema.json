{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ship Report",
  "description": "Schema for Phase 4 ship artifacts",
  "type": "object",
  "required": ["hasSummary", "hasActionItems", "minimumLines"],
  "properties": {
    "hasSummary": { "const": true, "description": "Must contain ## Summary or equivalent heading" },
    "hasActionItems": { "const": true, "description": "Must contain actionable items or configurations" },
    "minimumLines": { "type": "integer", "minimum": 10, "description": "Minimum line count" }
  }
}
