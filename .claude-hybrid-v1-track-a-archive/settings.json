{
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(src/**)",
      "Write(docs/**)",
      "Write(tests/**)",
      "Write(.github/**)",
      "Write(CLAUDE.md)",
      "Write(package.json)",
      "Write(tsconfig.json)",
      "Write(.env.example)",
      "Bash(npm run *)",
      "Bash(npx tsc *)",
      "Bash(npx prettier *)",
      "Bash(npx eslint *)",
      "Bash(npx jest *)",
      "Bash(npx playwright *)",
      "Bash(npx prisma *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git stash *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(mkdir *)"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(eval *)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.production)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-write-guard.mjs",
            "description": "Block writes to protected files and enforce file size limits",
            "blocking": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/security-scanner.mjs",
            "description": "Scan bash commands for dangerous patterns",
            "blocking": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/phase-gate.sh",
            "description": "Enforce phase prerequisites before /design, /build, /validate, /ship",
            "blocking": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null; exit 0",
            "description": "Auto-format after every file write"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/quality-gate.sh",
            "description": "Run tsc + lint + build on every session stop",
            "blocking": true
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session-end.sh",
            "description": "Auto-checkpoint memory and state files",
            "blocking": false
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
